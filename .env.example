# Shared
NODE_ENV=development
JWT_ACCESS_SECRET=replace-with-long-random-value
JWT_REFRESH_SECRET=replace-with-long-random-value
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cloud_notes

# Redis
REDIS_URL=redis://localhost:6379

# Backend
API_PORT=4000
API_BASE_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:5173

# Frontend
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Realtime
REALTIME_PORT=4010
REALTIME_JWT_SECRET=replace-with-long-random-value

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=note-attachments
S3_FORCE_PATH_STYLE=true
